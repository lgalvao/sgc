{
  "github": {
    "release": false
  },
  "git": {
    "tagName": "v${version}",
    "commitMessage": "chore(release): ${version}",
    "requireCleanWorkingDir": true
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:bump": [
      "node etc/scripts/projeto/versao-sincronizar.js ${version}"
    ]
  }
}
