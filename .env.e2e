# Ambiente de testes E2E - H2 em memória (schema.sql e seed.sql)
DB_URL=jdbc:h2:mem:testdb
DB_USERNAME=sa
DB_PASSWORD=
DB_DRIVER=org.h2.Driver
# Valor hardcoded no application.yml (perfil e2e) — mantido aqui para documentar e garantir
# que ferramentas que lêem o .env.e2e (ex: scripts externos) também tenham acesso ao segredo.
JWT_SECRET=sgc-secret-key-change-this-in-production-minimum-64-chars-for-hs512


# Configurações do Frontend
VITE_API_BASE_URL=/api
VITE_FEEDBACK_WIDGET=true
