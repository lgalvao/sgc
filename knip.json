{
  "workspaces": {
    ".": {
      "ignoreBinaries": [
        "playwright"
      ]
    },
    "e2e": {
      "entry": [
        "**/*.ts",
        "lifecycle.js"
      ],
      "project": [
        "**/*.ts",
        "**/*.js"
      ]
    },
    "frontend": {
      "entry": [
        "src/**/*.{ts,vue}",
        "src/**/*.stories.ts",
        "src/**/*.spec.ts",
        "src/**/*.d.ts",
        ".storybook/*.ts",
        ".dependency-cruiser.cjs"
      ],
      "project": [
        "src/**/*.{ts,vue}",
        "src/**/*.stories.ts",
        "src/**/*.spec.ts",
        "src/**/*.d.ts",
        ".storybook/*.ts"
      ],
      "ignoreDependencies": [
        "dependency-cruiser"
      ]
    },
    "toolkit": {
      "entry": [
        "**/*.js",
        "**/*.mjs",
        "**/*.cjs"
      ],
      "project": [
        "**/*.js",
        "**/*.mjs",
        "**/*.cjs"
      ]
    }
  }
}
