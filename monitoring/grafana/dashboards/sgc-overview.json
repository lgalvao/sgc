{
  "uid": "sgc-overview",
  "title": "SGC - Visão Geral",
  "tags": [
    "sgc"
  ],
  "timezone": "America/Recife",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Status da Aplicação",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "up{job=\"sgc\"}",
          "legendFormat": "SGC"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "thresholds": {
          "steps": [
            {
              "color": "red",
              "value": 0
            },
            {
              "color": "green",
              "value": 1
            }
          ]
        },
        "mappings": [
          {
            "options": {
              "0": {
                "text": "OFFLINE"
              },
              "1": {
                "text": "ONLINE"
              }
            },
            "type": "value"
          }
        ]
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Tempo Ativo (JVM)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "targets": [
        {
          "expr": "process_uptime_seconds{job=\"sgc\"}",
          "legendFormat": "Uptime"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "unit": "s"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Heap JVM Usado",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=\"sgc\", area=\"heap\"}",
          "legendFormat": "Heap"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "unit": "bytes"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Threads Ativas",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=\"sgc\"}",
          "legendFormat": "Threads"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Requisições HTTP por Segundo",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{job=\"sgc\"}[1m])",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latência HTTP (p95)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{job=\"sgc\"}[5m]))",
          "legendFormat": "p95 {{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Uso de Memória JVM",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=\"sgc\"}",
          "legendFormat": "{{area}} - {{id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Conexões de Banco (HikariCP)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=\"sgc\"}",
          "legendFormat": "Ativas"
        },
        {
          "expr": "hikaricp_connections_idle{job=\"sgc\"}",
          "legendFormat": "Ociosas"
        },
        {
          "expr": "hikaricp_connections_pending{job=\"sgc\"}",
          "legendFormat": "Aguardando"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Erros HTTP (4xx / 5xx)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{job=\"sgc\", status=~\"4..\"}[1m])",
          "legendFormat": "4xx {{uri}}"
        },
        {
          "expr": "rate(http_server_requests_seconds_count{job=\"sgc\", status=~\"5..\"}[1m])",
          "legendFormat": "5xx {{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "GC - Tempo de Pausa",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{job=\"sgc\"}[1m])",
          "legendFormat": "{{action}} - {{cause}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    }
  ]
}
