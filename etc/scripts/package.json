{
  "name": "sgc-scripts",
  "private": true,
  "type": "module",
  "description": "Toolkit unificado de scripts do SGC",
  "scripts": {
    "sgc": "node ./sgc.js",
    "deps:audit": "knip",
    "test": "vitest run",
    "lint": "oxlint . --node-plugin --vitest-plugin --disable-unicorn-plugin -D correctness -D suspicious --ignore-pattern node_modules --ignore-pattern test/fixtures",
    "lint:fix": "oxlint . --node-plugin --vitest-plugin --disable-unicorn-plugin -D correctness -D suspicious --ignore-pattern node_modules --ignore-pattern test/fixtures --fix"
  },
  "dependencies": {
    "@vue/compiler-sfc": "^3.5.35",
    "commander": "^14.0.3",
    "consola": "^3.4.2",
    "dependency-cruiser": "^17.4.2",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "globby": "^16.2.0",
    "listr2": "^10.2.1",
    "picocolors": "^1.1.1",
    "serve-handler": "^6.1.7",
    "ts-morph": "^28.0.0",
    "which": "^6.0.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.7",
    "knip": "^6.12.1",
    "oxlint": "^1.57.0",
    "vitest": "^4.1.2"
  }
}
