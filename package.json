{
  "name": "sgc",
  "description": "Sistema de Gestão de Competências",
  "version": "1.2.0",
  "type": "module",
  "workspaces": [
    "frontend",
    "toolkit",
    "e2e"
  ],
  "scripts": {
    "test": "npm --prefix frontend run test",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts --project=chromium",
    "test:unit": "npm --prefix frontend run test:unit",
    "typecheck": "npm run typecheck:e2e && npm --prefix frontend run typecheck",
    "typecheck:e2e": "npm run typecheck -w e2e",
    "sgc": "node toolkit/sgc.js",
    "smells:auditar": "node toolkit/sgc.js codigo smells auditar",
    "frontend:cruft": "node toolkit/sgc.js frontend cruft auditar",
    "frontend:cruft:check": "node toolkit/sgc.js frontend cruft validar",
    "frontend:arquitetura": "node toolkit/sgc.js frontend arquitetura auditar",
    "qa:dashboard": "node toolkit/sgc.js qa snapshot coletar --perfil rapido",
    "qa:dashboard:serve": "node toolkit/sgc.js qa dashboard servir --porta 4179",
    "lint:ox": "oxlint e2e toolkit eslint.config.js --ignore-pattern e2e/lifecycle.js",
    "lint": "npm run lint:ox && eslint e2e toolkit eslint.config.js --fix",
    "deps:audit": "knip",
    "deps:audit:all": "npm run deps:audit && npm --prefix frontend run deps:audit && npm --prefix toolkit run deps:audit",
    "release": "release-it"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.4",
    "form-data": "^4.0.6",
    "glob": "^13.0.0",
    "globals": "^17.6.0",
    "js-yaml": "^4.2.0",
    "knip": "^6.17.1",
    "oxlint": "^1.70.0",
    "release-it": "^20.2.0",
    "typescript": "^7.0.1-rc",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16"
  },
  "allowScripts": {
    "fsevents@2.3.3": true,
    "vue-demi@0.14.10": true,
    "esbuild@0.28.1": true
  },
  "overrides": {
    "typescript": "$typescript",
    "vue-tsc": {
      "typescript": "npm:@typescript/typescript6@latest"
    },
    "typescript-eslint": {
      "typescript": "npm:@typescript/typescript6@latest"
    },
    "@typescript-eslint/parser": {
      "typescript": "npm:@typescript/typescript6@latest"
    },
    "@typescript-eslint/utils": {
      "typescript": "npm:@typescript/typescript6@latest"
    },
    "sgc-frontend": {
      "vue-tsc": {
        "typescript": "npm:@typescript/typescript6@latest"
      },
      "typescript-eslint": {
        "typescript": "npm:@typescript/typescript6@latest"
      },
      "@typescript-eslint/parser": {
        "typescript": "npm:@typescript/typescript6@latest"
      },
      "@typescript-eslint/utils": {
        "typescript": "npm:@typescript/typescript6@latest"
      }
    },
    "js-yaml": "^4.2.0",
    "undici": "^7.28.0",
    "nodemailer": "^9.0.1",
    "openapi-typescript": {
      "@redocly/openapi-core": {
        "js-yaml": "^4.2.0"
      }
    },
    "sgc-scripts": {
      "openapi-typescript": {
        "@redocly/openapi-core": {
          "js-yaml": "^4.2.0"
        }
      }
    },
    "@redocly/openapi-core": {
      "js-yaml": "^4.2.0"
    }
  }
}
