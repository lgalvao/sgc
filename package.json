{
  "name": "sgc",
  "description": "Sistema de Gestão de Conhecimentos",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "npm test --prefix frontend",
    "test:unit": "npm run test:unit --prefix frontend",
    "test:e2e": "env -u NO_COLOR playwright test",
    "test:e2e:poc": "env -u NO_COLOR E2E_WORKERS=2 playwright test",
    "test:e2e:captura": "playwright test e2e/captura-telas.spec.ts",
    "typecheck": "npm run typecheck --prefix frontend && npm run typecheck:e2e",
    "typecheck:e2e": "tsc --noEmit -p e2e/tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "@types/smtp-server": "^3.5.12",
    "@vitest/browser-preview": "^4.0.18",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.9.0",
    "globals": "^16.5.0",
    "lighthouse": "^13.0.3",
    "smtp-server": "^3.18.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "xml2js": "^0.6.2"
  }
}
