{
  "name": "sgc",
  "description": "Sistema de Gestão de Conhecimentos",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "npm test --prefix frontend",
    "test:unit": "npm run test:unit --prefix frontend",
    "test:e2e": "playwright test",
    "qa:dashboard": "powershell -ExecutionPolicy Bypass -File etc/qa-dashboard/scripts/coletar-snapshot.ps1 -Perfil rapido",
    "typecheck": "npm run typecheck --prefix frontend && npm run typecheck:e2e",
    "typecheck:e2e": "tsc --noEmit -p e2e/tsconfig.json",
    "lint:ox": "oxlint .",
    "lint": "npm run lint:ox && eslint . --fix",
    "sast": "semgrep scan --config p/java --config p/typescript --config p/javascript --config p/owasp-top-ten --config p/security-audit --config p/secrets --metrics=off"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/smtp-server": "^3.5.12",
    "@vitest/browser-preview": "^4.0.18",
    "axe-playwright": "^2.2.2",
    "chrome-launcher": "^1.2.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.1",
    "globals": "^17.4.0",
    "oxlint": "^1.57.0",
    "smtp-server": "^3.18.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "xml2js": "^0.6.2"
  }
}
