{
  "name": "sgc-frontend",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build": "vite build",
    "build:hom": "vite build --mode hom",
    "build:e2e": "vite build --mode e2e",
    "build:prod": "vite build --mode production",
    "lint:ox": "oxlint --ignore-path .oxlintignore .",
    "lint": "npm run lint:ox && eslint . --fix",
    "deps:audit": "knip",
    "typecheck": "vue-tsc --noEmit --skipLibCheck --incremental --strict",
    "test": "npm run test:unit",
    "test:unit": "vitest --run --reporter=dot --no-color",
    "coverage:unit": "vitest --run --coverage --reporter=dot --no-color",
    "coverage:unit:collect": "vitest --run --coverage --reporter=dot --no-color --coverage.thresholds.lines=0 --coverage.thresholds.functions=0 --coverage.thresholds.statements=0 --coverage.thresholds.branches=0",
    "diagnostico:cache:audit": "node scripts/auditar-cache-diagnostico.mjs",
    "cruft:audit": "node ../toolkit/sgc.js frontend cruft auditar",
    "arquitetura:audit": "node ../toolkit/sgc.js frontend arquitetura auditar",
    "arquitetura:gate": "node ../toolkit/sgc.js frontend arquitetura validar",
    "modais:check": "node ../toolkit/sgc.js frontend modais validar",
    "templates:check": "node ../toolkit/sgc.js frontend views templates-validar",
    "cruft:check": "node ../toolkit/sgc.js frontend cruft validar",
    "quality:test": "npm run test:unit",
    "quality:lint": "oxlint --ignore-path .oxlintignore . && eslint . --max-warnings 0",
    "quality:typecheck": "vue-tsc --noEmit --skipLibCheck --incremental --strict",
    "quality:all": "npm run quality:test && npm run quality:lint && npm run quality:typecheck && npm run cruft:check && npm run arquitetura:gate && npm run templates:check && npm run modais:check"
  },
  "dependencies": {
    "@pinia/colada": "^1.3.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@tiptap/vue-3": "^3.27.1",
    "axios": "^1.18.1",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "bootstrap-vue-next": "^0.45.7",
    "date-fns": "^4.4.0",
    "html2canvas": "^1.4.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@chialab/vitest-axe": "^0.19.1",
    "@eslint/js": "^10.0.1",
    "@pinia/testing": "^1.0.3",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-links": "^10.4.6",
    "@storybook/vue3-vite": "^10.4.6",
    "@types/bootstrap": "^5.2.11",
    "@types/node": "^26.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "axe-core": "^4.12.1",
    "consola": "^3.4.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^10.4.6",
    "eslint-plugin-vue": "^10.9.2",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "fast-check": "^4.8.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.23.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "rollup": "^4.62.2",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.1",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.6"
  }
}
