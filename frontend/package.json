{
  "name": "sgc",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build": "vite build",
    "preview": "vite preview",
    "lint:ox": "oxlint .",
    "lint": "npm run lint:ox && eslint . --ext .vue,.js,.mjs,.ts --fix",
    "typecheck": "vue-tsc --noEmit --skipLibCheck --incremental --strict",
    "test": "npm run test:unit",
    "test:unit": "vitest --run --reporter=dot --no-color",
    "coverage:unit": "vitest --run --coverage --reporter=dot --no-color",
    "quality:test": "vitest --run --coverage --reporter=dot --no-color",
    "quality:lint": "oxlint . && eslint . --ext .vue,.js,.mjs,.ts --max-warnings 0 --ignore-pattern coverage --ignore-pattern dist || true",
    "quality:typecheck": "vue-tsc --noEmit --skipLibCheck --incremental --strict || true",
    "quality:all": "npm run quality:test && npm run quality:lint && npm run quality:typecheck"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "bootstrap-vue-next": "^0.44.1",
    "date-fns": "^4.1.0",
    "papaparse": "^5.5.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chialab/vitest-axe": "^0.19.1",
    "@eslint/js": "^10.0.1",
    "@pinia/testing": "^1.0.3",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-links": "^10.3.4",
    "@storybook/vue3-vite": "^10.3.4",
    "@testing-library/vue": "^8.1.0",
    "@types/bootstrap": "^5.2.10",
    "@types/node": "^25.5.2",
    "@types/papaparse": "^5.5.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser-preview": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "@vue/typescript-plugin": "^3.2.6",
    "axe-core": "^4.11.2",
    "consola": "^3.4.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "10.3.4",
    "eslint-plugin-vue": "^10.8.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "fast-check": "^4.6.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "openapi-typescript": "^7.13.0",
    "oxlint": "^1.58.0",
    "playwright": "^1.59.1",
    "storybook": "^10.3.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  }
}
