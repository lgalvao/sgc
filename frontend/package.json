{
  "name": "sgc",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build": "vite build",
    "build:hom": "vite build --mode hom",
    "build:e2e": "vite build --mode e2e",
    "build:prod": "vite build --mode production",
    "lint:ox": "oxlint --ignore-path .oxlintignore .",
    "lint": "npm run lint:ox && eslint . --fix",
    "deps:audit": "knip",
    "typecheck": "vue-tsc --noEmit --skipLibCheck --incremental --strict",
    "test": "npm run test:unit",
    "test:unit": "vitest --run --reporter=dot --no-color",
    "coverage:unit": "vitest --run --coverage --reporter=dot --no-color",
    "coverage:unit:collect": "vitest --run --coverage --reporter=dot --no-color --coverage.thresholds.lines=0 --coverage.thresholds.functions=0 --coverage.thresholds.statements=0 --coverage.thresholds.branches=0",
    "cruft:audit": "node ../toolkit/sgc.js frontend cruft auditar",
    "arquitetura:audit": "node ../toolkit/sgc.js frontend arquitetura auditar",
    "arquitetura:gate": "node ../toolkit/sgc.js frontend arquitetura validar",
    "cruft:check": "node ../toolkit/sgc.js frontend cruft validar",
    "quality:test": "npm run test:unit",
    "quality:lint": "oxlint --ignore-path .oxlintignore . && eslint . --max-warnings 0",
    "quality:typecheck": "vue-tsc --noEmit --skipLibCheck --incremental --strict",
    "quality:all": "npm run quality:test && npm run quality:lint && npm run quality:typecheck && npm run cruft:check && npm run arquitetura:gate"
  },
  "dependencies": {
    "@pinia/colada": "^1.3.1",
    "@tiptap/starter-kit": "^3.23.1",
    "@tiptap/vue-3": "^3.23.1",
    "axios": "^1.18.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "bootstrap-vue-next": "^0.45.2",
    "date-fns": "^4.2.0",
    "html2canvas": "^1.4.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@chialab/vitest-axe": "^0.19.1",
    "@eslint/js": "^10.0.1",
    "@pinia/testing": "^1.0.3",
    "@storybook/addon-docs": "^10.4.5",
    "@storybook/addon-links": "^10.4.5",
    "@storybook/vue3-vite": "^10.4.5",
    "@types/bootstrap": "^5.2.10",
    "@types/node": "^25.6.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "axe-core": "^4.11.4",
    "consola": "^3.4.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^0.12.0",
    "eslint-plugin-vue": "^10.9.1",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "fast-check": "^4.7.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "knip": "^6.12.1",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.23.0",
    "rollup": "^4.60.3",
    "storybook": "^10.4.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.8"
  },
  "overrides": {
    "glob": "^13.0.0"
  },
  "allowScripts": {
    "vue-demi@0.14.10": true,
    "fsevents@2.3.3": true,
    "esbuild@0.25.12": true
  }
}
