  },
  "dependencies": {
    "@vue/compiler-sfc": "^3.5.38",
    "commander": "^15.0.0",
    "consola": "^3.4.2",
    "dependency-cruiser": "^17.4.3",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "globby": "^16.2.0",
    "js-yaml": "^4.2.0",
    "listr2": "^10.2.1",
    "openapi-diff": "^0.24.1",
    "openapi-typescript": "^7.13.0",
    "picocolors": "^1.1.1",
    "serve-handler": "^6.1.7",
    "ts-morph": "^28.0.0",
    "which": "^7.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "knip": "^6.17.1",
    "oxlint": "^1.70.0",
    "vitest": "^4.1.9"
